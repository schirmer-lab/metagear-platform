---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="mg-site-footer not-content">
  <div class="mg-site-footer__grid">
    <div class="mg-site-footer__brand">
      <div class="mg-site-footer__wordmark">
        Meta<em>GEAR</em>
      </div>
      <p class="mg-site-footer__tag">
        An integrated bioinformatics platform for microbiome research, developed
        at the <a href="https://www.mls.ls.tum.de/en/mdi/home/">Schirmer Lab</a>.
      </p>
    </div>

    <div>
      <h4>Platform</h4>
      <ul>
        <li><a href={`${base}/about/`}>What is MetaGEAR</a></li>
        <li><a href={`${base}/get-started/`}>Get started</a></li>
        <li><a href={`${base}/cite/`}>Cite &amp; contact</a></li>
        <li><a href={`${base}/news/`}>News</a></li>
      </ul>
    </div>

    <div>
      <h4>Components</h4>
      <ul>
        <li><a href={`${base}/workflows/`}>MetaGEAR Workflows</a></li>
        <li><a href={`${base}/tools/`}>MetaGEAR Tools (CLI)</a></li>
        <li><a href={`${base}/explorer/`}>MetaGEAR Explorer</a></li>
      </ul>
    </div>

    <div>
      <h4>Source</h4>
      <ul>
        <li><a href="https://github.com/schirmer-lab/metagear-pipeline">metagear-pipeline</a></li>
        <li><a href="https://github.com/schirmer-lab/metagear-tools">metagear-tools</a></li>
        <li><a href="https://metagear-explorer.schirmerlab.de">Explorer (hosted)</a></li>
        <li><a href="https://github.com/schirmer-lab/metagear">This site</a></li>
      </ul>
    </div>
  </div>

  <div class="mg-site-footer__legal">
    <span class="mg-site-footer__lab">
      © {year} <strong><a href="https://www.mls.ls.tum.de/en/mdi/home/">Schirmer Lab</a></strong>
      <span style="opacity:0.5">·</span> MIT-licensed open source
    </span>
    <span>
      <a href={`${base}/cite/`}>Cite this work →</a>
    </span>
  </div>
</footer>
